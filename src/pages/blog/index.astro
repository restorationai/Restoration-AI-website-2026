---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// Drafts are visible in local dev (for review) but excluded from the production build.
const all = (await getCollection('blog'))
  .filter((p) => import.meta.env.DEV || !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const CATEGORY_STYLES: Record<string, string> = {
  'Never Miss a Call':     'bg-blue-50 text-blue-700 border-blue-100',
  'Dispatch on Autopilot': 'bg-violet-50 text-violet-700 border-violet-100',
  'Get Paid More':         'bg-green-50 text-green-700 border-green-100',
  'Connect Your Stack':    'bg-orange-50 text-orange-700 border-orange-100',
  'Get More Calls':        'bg-teal-50 text-teal-700 border-teal-100',
  'Serve Every Customer':  'bg-rose-50 text-rose-700 border-rose-100',
};

type Card = {
  slug: string;
  title: string;
  description?: string;
  publishedAt: Date;
  hero?: string;
  heroAlt?: string;
  category: string;
};

const enriched: Card[] = all.map((p) => ({
  slug: p.id,
  title: p.data.title,
  description: p.data.seoDescription,
  publishedAt: p.data.publishedAt,
  hero: p.data.hero,
  heroAlt: p.data.heroAlt ?? p.data.title,
  category: p.data.category ?? 'General',
}));

const categories = ['All', ...Array.from(new Set(enriched.map((p) => p.category)))];
const [featured, ...rest] = enriched;

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Restoration AI Blog',
  description: 'Guides on AI dispatch, missed calls, IICRC water loss categories, and automated restoration workflows.',
  url: 'https://restorationai.io/blog',
  blogPost: enriched.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    description: p.description,
    datePublished: p.publishedAt.toISOString(),
    url: `https://restorationai.io/blog/${p.slug}`,
  })),
};
---

<MainLayout
  title="Blog | Restoration AI"
  description="Guides on AI answering, after-hours dispatch, IICRC water categories, and how restoration contractors run 24/7 emergency operations."
  jsonLd={blogJsonLd}
>
  <!-- HERO -->
  <section class="pt-36 pb-16 bg-slate-900 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[80%] rounded-full bg-blue-500/10 blur-[120px]"></div>
      <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[80%] rounded-full bg-blue-400/10 blur-[120px]"></div>
    </div>
    <div class="container-pill relative z-10">
      <p class="text-sm font-semibold text-[#3dd0ff] uppercase tracking-[0.2em] mb-4">Restoration AI Blog</p>
      <h1 class="text-5xl md:text-6xl font-extrabold text-white tracking-tight leading-[1.1] mb-6 max-w-3xl">
        Stop losing jobs.<br />Start winning more.
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl">
        Deep dives on AI answering, after-hours dispatch, IICRC water categories, and the systems restoration contractors use to run 24/7 operations.
      </p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 bg-white min-h-[60vh]">
    <div class="container-pill">

      {enriched.length === 0 ? (
        <!-- EMPTY STATE -->
        <div class="py-20 text-center">
          <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 text-blue-700 text-sm font-semibold px-4 py-2 rounded-full mb-8">
            <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
            New articles dropping weekly
          </div>
          <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Coming soon</h2>
          <p class="text-slate-500 max-w-lg mx-auto mb-12">
            We're publishing in-depth guides on every topic restoration contractors need to run a tighter operation.
          </p>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl mx-auto text-left">
            {[
              { cat: 'Never Miss a Call',     title: 'How AI Triages IICRC Water Categories at 2am',         style: CATEGORY_STYLES['Never Miss a Call'] },
              { cat: 'Get Paid More',     title: 'Why Speed-to-Lead Wins More Restoration Jobs',          style: CATEGORY_STYLES['Get Paid More'] },
              { cat: 'Dispatch on Autopilot', title: 'How to Automate Restoration Job Dispatch End-to-End',   style: CATEGORY_STYLES['Dispatch on Autopilot'] },
              { cat: 'Connect Your Stack',    title: 'AI Phone Systems That Sync With JobNimbus & Xcelerate', style: CATEGORY_STYLES['Connect Your Stack'] },
              { cat: 'Get More Calls',        title: 'How Restoration Companies Dominate AI Search Results',  style: CATEGORY_STYLES['Get More Calls'] },
              { cat: 'Serve Every Customer',  title: 'After-Hours Answering for Restoration Contractors',     style: CATEGORY_STYLES['Serve Every Customer'] },
            ].map(({ cat, title, style }) => (
              <div class="p-5 border border-slate-100 rounded-2xl bg-slate-50 opacity-60">
                <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full border mb-3 ${style}`}>{cat}</span>
                <p class="text-sm font-semibold text-slate-700 leading-snug">{title}</p>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div>
          <!-- CATEGORY FILTER PILLS -->
          <div class="flex flex-wrap gap-2 mb-12" id="category-filters">
            {categories.map((cat, i) => (
              <button
                data-filter={cat}
                class={`category-pill px-4 py-2 rounded-full text-sm font-semibold border transition-all ${
                  i === 0
                    ? 'bg-slate-900 text-white border-slate-900'
                    : 'bg-white text-slate-600 border-slate-200 hover:border-slate-400'
                }`}
              >
                {cat}
              </button>
            ))}
          </div>

          <!-- FEATURED POST -->
          <a
            href={`/blog/${featured.slug}`}
            data-post-card
            data-category={featured.category}
            class="group grid md:grid-cols-2 gap-0 rounded-3xl overflow-hidden border border-slate-200 hover:border-[#3dd0ff] transition-all mb-12 shadow-sm hover:shadow-lg"
          >
            <!-- Image -->
            <div class="aspect-video md:aspect-auto bg-slate-900 relative overflow-hidden">
              {featured.hero ? (
                <img
                  src={featured.hero}
                  alt={featured.heroAlt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="eager"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                  <span class="text-6xl opacity-20">📡</span>
                </div>
              )}
            </div>
            <!-- Content -->
            <div class="p-8 md:p-12 flex flex-col justify-center bg-white">
              <div class="flex items-center gap-3 mb-4">
                <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full border ${CATEGORY_STYLES[featured.category] ?? 'bg-slate-50 text-slate-600 border-slate-200'}`}>
                  {featured.category}
                </span>
                <span class="text-xs font-bold text-[#3dd0ff] uppercase tracking-widest">Latest</span>
              </div>
              <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight mb-4 group-hover:text-[#26bdef] transition-colors">
                {featured.title}
              </h2>
              {featured.description && (
                <p class="text-slate-500 leading-relaxed mb-6 line-clamp-3">{featured.description}</p>
              )}
              <div class="flex items-center justify-between">
                <p class="text-xs text-slate-400">
                  {featured.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <span class="text-sm font-semibold text-[#3dd0ff] group-hover:underline">Read article →</span>
              </div>
            </div>
          </a>

          <!-- POST GRID -->
          {rest.length > 0 && (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="post-grid">
              {rest.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  data-post-card
                  data-category={post.category}
                  class="group flex flex-col rounded-2xl overflow-hidden border border-slate-200 hover:border-[#3dd0ff] transition-all shadow-sm hover:shadow-md"
                >
                  <!-- Thumbnail -->
                  <div class="aspect-video bg-slate-900 relative overflow-hidden">
                    {post.hero ? (
                      <img
                        src={post.hero}
                        alt={post.heroAlt}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                        <span class="text-4xl opacity-20">📡</span>
                      </div>
                    )}
                  </div>
                  <!-- Content -->
                  <div class="p-6 flex flex-col flex-1 bg-white">
                    <span class={`inline-block self-start text-xs font-semibold px-2.5 py-1 rounded-full border mb-3 ${CATEGORY_STYLES[post.category] ?? 'bg-slate-50 text-slate-600 border-slate-200'}`}>
                      {post.category}
                    </span>
                    <h2 class="text-lg font-bold text-slate-900 leading-snug mb-3 group-hover:text-[#26bdef] transition-colors flex-1">
                      {post.title}
                    </h2>
                    {post.description && (
                      <p class="text-sm text-slate-500 line-clamp-2 mb-4">{post.description}</p>
                    )}
                    <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100">
                      <p class="text-xs text-slate-400">
                        {post.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </p>
                      <span class="text-xs font-semibold text-[#3dd0ff]">Read →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}

          <!-- NO RESULTS for a category filter -->
          <div id="no-results" class="hidden py-16 text-center">
            <p class="text-slate-400 text-lg">No posts in this category yet.</p>
          </div>
        </div>
      )}

    </div>
  </section>
</MainLayout>

<script is:inline>
  const pills = document.querySelectorAll('.category-pill');
  const cards = document.querySelectorAll('[data-post-card]');
  const noResults = document.getElementById('no-results');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter;

      // Update active pill styles
      pills.forEach((p) => {
        p.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
        p.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
      });
      pill.classList.add('bg-slate-900', 'text-white', 'border-slate-900');
      pill.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const match = filter === 'All' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
