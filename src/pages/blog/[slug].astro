---
import MainLayout from '../../layouts/MainLayout.astro';
import { sanityClient, POST_BY_SLUG_QUERY, type Post } from '../../sanity/client';
import { toHTML } from '@portabletext/to-html';
import manifest from '../../../CONTENT_MANIFEST.json';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch<Post[]>(
    `*[_type == "post" && defined(slug.current)]{ slug }`
  );
  return posts.map((p) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch<Post | null>(POST_BY_SLUG_QUERY, { slug });

if (!post) {
  return Astro.redirect('/blog');
}

const bodyHtml = post.body ? toHTML(post.body) : '';

// Internal linking: resolve parent pillar from manifest at build time
const pipelineEntry = manifest.production_pipeline.find(
  (p) => p.slug === `/blog/${slug}`
);
const topicEntry = pipelineEntry
  ? manifest.topical_map.find((t) => t.topic_id === pipelineEntry.topic_id)
  : null;
const parentPillarEntry = topicEntry?.parent_pillar_id
  ? manifest.topical_map.find((t) => t.topic_id === topicEntry.parent_pillar_id)
  : null;
const parentPillarPipeline = parentPillarEntry
  ? manifest.production_pipeline.find((p) => p.topic_id === parentPillarEntry.topic_id)
  : null;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.seoTitle ?? post.title,
  description: post.seoDescription,
  datePublished: post.publishedAt,
  author: {
    '@type': 'Organization',
    name: 'Restoration AI',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Restoration AI',
    logo: {
      '@type': 'ImageObject',
      url: 'https://restorationai.io/favicon.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://restorationai.io/blog/${post.slug.current}`,
  },
};
---

<MainLayout
  title={`${post.seoTitle ?? post.title} | Restoration AI`}
  description={post.seoDescription ?? ''}
  jsonLd={articleJsonLd}
>
  <article class="py-32 bg-white">
    <div class="container-pill max-w-3xl">
      {post.publishedAt && (
        <p class="text-sm text-slate-400 mb-4">
          {new Date(post.publishedAt).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      )}
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-6">
        {post.title}
      </h1>
      {post.seoDescription && (
        <p class="text-xl text-slate-500 mb-10 leading-relaxed">{post.seoDescription}</p>
      )}

      {parentPillarPipeline && (
        <a
          href={parentPillarPipeline.slug}
          class="inline-flex items-center gap-2 mb-10 px-4 py-2.5 bg-blue-50 border border-blue-100 rounded-xl text-sm font-semibold text-blue-700 hover:bg-blue-100 transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Part of our guide: {parentPillarEntry!.primary_keyword}
        </a>
      )}

      {post.loomVideoUrl && (
        <div class="aspect-video w-full mb-12 rounded-2xl overflow-hidden border border-slate-200">
          <iframe
            src={post.loomVideoUrl}
            class="w-full h-full"
            frameborder="0"
            allowfullscreen
          ></iframe>
        </div>
      )}

      <div class="prose prose-slate max-w-none" set:html={bodyHtml}></div>

      <div class="mt-16 pt-8 border-t border-slate-200">
        <a href="/blog" class="text-[#3dd0ff] font-medium hover:underline">← Back to all posts</a>
      </div>
    </div>
  </article>
</MainLayout>
