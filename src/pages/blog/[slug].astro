---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { getAuthor } from '../../data/authors';

export async function getStaticPaths() {
  // Drafts render in local dev (for review) but are excluded from the production build.
  const posts = (await getCollection('blog')).filter((p) => import.meta.env.DEV || !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);
const author = getAuthor(data.author);

const url = `https://restorationai.io/blog/${post.id}`;
const heroUrl = data.hero
  ? (data.hero.startsWith('http') ? data.hero : `https://restorationai.io${data.hero}`)
  : undefined;

// --- Auto-generate FAQ from answer-capsule H2s (H2 ending in "?" + its first
// paragraph). Powers a FAQPage rich result and feeds AI answer engines. ---
function buildFaq(md: string) {
  const lines = md.split('\n');
  const faqs: { q: string; a: string }[] = [];
  for (let i = 0; i < lines.length; i++) {
    const m = lines[i].match(/^##\s+(.*\?)\s*$/);
    if (!m) continue;
    let j = i + 1;
    while (j < lines.length && !lines[j].trim()) j++;
    const ans: string[] = [];
    while (j < lines.length && lines[j].trim() && !lines[j].startsWith('#')) {
      ans.push(lines[j]);
      j++;
    }
    const text = ans
      .join(' ')
      .replace(/!\[[^\]]*\]\([^)]*\)/g, '')          // drop images
      .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')        // links -> anchor text
      .replace(/[*_>`#]/g, '')                         // strip md emphasis
      .replace(/\s+/g, ' ')
      .trim();
    if (text) faqs.push({ q: m[1].trim(), a: text });
  }
  return faqs;
}
const faqs = buildFaq(post.body ?? '');

const personSchema = {
  '@type': 'Person',
  name: author.name,
  url: author.url,
  ...(author.photo && { image: `https://restorationai.io${author.photo}` }),
  ...(author.sameAs?.length && { sameAs: author.sameAs }),
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.seoTitle ?? data.title,
  description: data.seoDescription,
  ...(heroUrl && { image: heroUrl }),
  datePublished: data.publishedAt.toISOString(),
  ...(data.updatedAt && { dateModified: data.updatedAt.toISOString() }),
  author: personSchema,
  publisher: {
    '@type': 'Organization',
    name: 'Restoration AI',
    logo: {
      '@type': 'ImageObject',
      url: 'https://restorationai.io/favicon.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restorationai.io/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://restorationai.io/blog' },
    { '@type': 'ListItem', position: 3, name: data.title, item: url },
  ],
};

const faqJsonLd = faqs.length >= 2
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const jsonLd = [articleJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])];
---

<MainLayout
  title={`${data.seoTitle ?? data.title} | Restoration AI`}
  description={data.seoDescription ?? ''}
  ogImage={heroUrl}
  jsonLd={jsonLd}
>
  <article class="py-32 bg-white">
    <div class="container-pill max-w-3xl">

      <!-- BREADCRUMBS -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-400">
          <li><a href="/" class="hover:text-[#26bdef]">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog" class="hover:text-[#26bdef]">Blog</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-slate-600 font-medium line-clamp-1">{data.title}</li>
        </ol>
      </nav>

      <p class="text-sm text-slate-400 mb-4">
        {data.publishedAt.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </p>
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-6">
        {data.title}
      </h1>
      {data.seoDescription && (
        <p class="text-xl text-slate-500 mb-10 leading-relaxed">{data.seoDescription}</p>
      )}

      {data.pillarSlug && data.pillarLabel && (
        <a
          href={data.pillarSlug}
          class="inline-flex items-center gap-2 mb-10 px-4 py-2.5 bg-blue-50 border border-blue-100 rounded-xl text-sm font-semibold text-blue-700 hover:bg-blue-100 transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Part of our guide: {data.pillarLabel}
        </a>
      )}

      {data.hero && (
        <div class="w-full mb-12 rounded-2xl overflow-hidden border border-slate-200">
          <img
            src={data.hero}
            alt={data.heroAlt ?? data.title}
            width="1200"
            height="630"
            class="w-full object-cover"
            loading="eager"
          />
        </div>
      )}

      {data.loomVideoUrl && (
        <div class="aspect-video w-full mb-12 rounded-2xl overflow-hidden border border-slate-200">
          <iframe
            src={data.loomVideoUrl}
            class="w-full h-full"
            frameborder="0"
            allowfullscreen
          ></iframe>
        </div>
      )}

      <div class="blog-content max-w-none">
        <Content />
      </div>

      <!-- AUTHOR BOX (E-E-A-T) -->
      <aside class="mt-16 pt-10 border-t border-slate-200">
        <div class="flex flex-col sm:flex-row gap-6 items-start bg-slate-50 border border-slate-100 rounded-2xl p-6">
          <img
            src={author.photo}
            alt={author.photoAlt}
            width="96"
            height="96"
            loading="lazy"
            class="w-24 h-24 rounded-full object-cover border border-slate-200 shrink-0"
          />
          <div>
            <p class="text-xs font-semibold text-[#3dd0ff] uppercase tracking-widest mb-1">About the author</p>
            <h2 class="text-lg font-bold text-slate-900">{author.name}</h2>
            <p class="text-sm font-medium text-slate-500 mb-3">{author.title}</p>
            <p class="text-sm text-slate-600 leading-relaxed">{author.bio}</p>
            {author.linkedin && (
              <a
                href={author.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-3 text-sm font-semibold text-[#10a2d9] hover:text-[#26bdef]"
              >
                Connect on LinkedIn →
              </a>
            )}
          </div>
        </div>
      </aside>

      <div class="mt-12 pt-8 border-t border-slate-200">
        <a href="/blog" class="text-[#3dd0ff] font-medium hover:underline">← Back to all posts</a>
      </div>
    </div>
  </article>
</MainLayout>
