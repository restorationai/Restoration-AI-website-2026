---
import MainLayout from '../layouts/MainLayout.astro';
import ThankYouHero from '../components/ThankYouHero';
import StatsBanner from '../components/StatsBanner';
import CallRecordings from '../components/CallRecordings';
import BuiltForRestoration from '../components/BuiltForRestoration';
import FeaturesShowcase from '../components/FeaturesShowcase';
import HowItWorks from '../components/HowItWorks';
import Integrations from '../components/Integrations';
import Testimonials from '../components/Testimonials';
import FAQ from '../components/FAQ';
import ComparisonTable from '../components/ComparisonTable';
import TryItYourself from '../components/TryItYourself';
---

<MainLayout title="Thank You! | Restoration AI" description="Your strategy call has been scheduled.">
  <ThankYouHero client:load />
  <StatsBanner client:idle />
  <div class="relative w-full bg-[#fafbfe] overflow-x-clip">
    <BuiltForRestoration client:visible />
    <CallRecordings client:visible />
    <HowItWorks client:visible />
    <FeaturesShowcase client:visible />
    <ComparisonTable client:visible />
    <Testimonials client:visible />
    <TryItYourself client:visible />
    <Integrations client:visible />
    <FAQ client:visible />
  </div>

  {/* Meta Pixel Conversion Event for Booking a Call */}
  <script is:inline>
    // Fire the Facebook Pixel Lead event when the thank you page loads
    if (typeof fbq === 'function') {
      fbq('track', 'Lead');
      fbq('track', 'Schedule');
    }
  </script>
</MainLayout>
