---
import MainLayout from "../../layouts/MainLayout.astro";
import XcelerateHomepage from "../../components/integrations/XcelerateHomepage";
import XcelerateFAQ from "../../components/integrations/XcelerateFAQ.astro";
import XcelerateCTA from "../../components/integrations/XcelerateCTA.astro";

const serviceJsonLd = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Automated Restoration Dispatch for Xcelerate",
    serviceType: "AI Receptionist & Automation",
    provider: {
        "@type": "SoftwareApplication",
        name: "Restoration AI",
    },
    description:
        "Automated 24/7 call answering, lead qualification, and emergency crew dispatch directly integrated into Xcelerate for restoration contractors.",
    areaServed: "Worldwide",
};

const faqJsonLd = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "Does Restoration AI integrate directly with Xcelerate?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Restoration AI is designed to work seamlessly with your Xcelerate workflow by capturing calls, structuring job details, and delivering organized information that fits your process. The goal is to ensure every job starts with complete and accurate data so your team can take action immediately without fixing intake issues first.",
            },
        },
        {
            "@type": "Question",
            name: "Do I have to change how my team uses Xcelerate?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "No. Your team continues using Xcelerate exactly the way they already do today. Restoration AI does not replace your system or force a new process. It improves what happens before the job reaches your system so your team receives cleaner, more consistent information without changing how they work.",
            },
        },
        {
            "@type": "Question",
            name: "Will this slow down our intake calls?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "No. Restoration AI is configured around your intake process and only asks the questions that matter. Calls remain smooth and efficient while still capturing the information your team needs. The goal is to improve quality without creating friction.",
            },
        },
        {
            "@type": "Question",
            name: "What does this actually improve if I already use Xcelerate?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Xcelerate works best when jobs start with complete information. In many cases, intake is inconsistent, which leads to missing details and extra work later. Restoration AI ensures every job starts clean and structured so your team can move faster without fixing or chasing information.",
            },
        },
        {
            "@type": "Question",
            name: "Can it handle after-hours calls and high call volume?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Yes. Restoration AI operates 24 hours a day, including nights, weekends, and storm events. Every call is answered immediately, preventing missed opportunities and allowing your business to capture more jobs during peak demand.",
            },
        },
        {
            "@type": "Question",
            name: "Is this built specifically for restoration companies?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Yes. Restoration AI is built specifically for restoration workflows and understands the urgency, job types, and intake requirements unique to restoration businesses.",
            },
        },
        {
            "@type": "Question",
            name: "How quickly can we get set up?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Most companies can get started quickly because there is no need to rebuild workflows or replace systems. Restoration AI is configured around how your business already operates, allowing you to begin capturing better jobs without a long onboarding process.",
            },
        },
    ],
};
---

<MainLayout jsonLd={[serviceJsonLd, faqJsonLd]}>
    <XcelerateHomepage client:load />
    <XcelerateFAQ />
    <XcelerateCTA />
</MainLayout>
