---
import BookACall from "../../components/BookACall";
import MainLayout from "../../layouts/MainLayout.astro";
import AlbiwareHomepage from "../../components/integrations/AlbiwareHomepage";

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Automated Restoration Dispatch for Albiware",
  serviceType: "AI Receptionist & Automation",
  provider: {
    "@type": "SoftwareApplication",
    name: "Restoration AI",
  },
  description:
    "Automated 24/7 call answering, lead qualification, and emergency crew dispatch directly integrated into Albiware for restoration contractors.",
  areaServed: "Worldwide",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Does Restoration AI integrate directly with Albiware?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Restoration AI is designed to work seamlessly alongside your Albiware workflow by capturing calls, structuring the job details, and delivering everything your team needs in a clean, organized format. The goal is not to change how your system works, but to make sure every job enters Albiware with complete and accurate information so your team can act immediately without fixing intake issues first.",
      },
    },
    {
      "@type": "Question",
      name: "Do I have to change how my team uses Albiware?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Your team continues using Albiware exactly the way they already do today. Restoration AI does not replace your system or force a new process. Instead, it improves what happens before the job reaches Albiware by making sure every call is handled properly and every job starts with the right information.",
      },
    }
  ],
};
---

<MainLayout title="Automated Restoration Dispatch for Albiware | Restoration AI" description="Automated 24/7 call answering, lead qualification, and emergency crew dispatch directly integrated into Albiware for restoration contractors." jsonLd={[serviceJsonLd, faqJsonLd]}>
    <AlbiwareHomepage client:visible />
    <BookACall client:visible />
</MainLayout>
