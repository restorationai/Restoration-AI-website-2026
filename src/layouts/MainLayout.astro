---
import "../styles/globals.css";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title = "Restoration AI | AI Receptionist & Automated Dispatch for Restoration Contractors",
  description = "AI receptionist, automated dispatch, and marketing CRM tailored specifically for the restoration industry. Never miss a call. Never lose a job.",
  canonical,
  jsonLd,
} = Astro.props;

const siteUrl = "https://restorationai.io";
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, siteUrl).toString();

const appJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Restoration AI",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description:
    "AI receptionist, automated dispatch, and marketing CRM tailored specifically for the restoration industry.",
  url: siteUrl,
  offers: {
    "@type": "Offer",
    price: "349.00",
    priceCurrency: "USD",
  },
};

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Restoration AI",
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  contactPoint: {
    "@type": "ContactPoint",
    email: "contact@restorationai.io",
    contactType: "customer support",
  },
};

const pageJsonLdArray = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Restoration AI" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- AEO signals -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Forced Light Mode Logic -->
    <script is:inline>
      document.documentElement.classList.remove("dark");
      window.localStorage.setItem("theme", "light");
    </script>

    <!-- Schema.org: SoftwareApplication -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(appJsonLd)}
    />

    <!-- Schema.org: Organization -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(orgJsonLd)}
    />

    {
      pageJsonLdArray.map((entry) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(entry)}
        />
      ))
    }

    <style is:global>
      /* Hide scrollbar for Chrome, Safari and Opera */
      ::-webkit-scrollbar {
        display: none !important;
      }
      /* Hide scrollbar for IE, Edge and Firefox */
      html, body {
        -ms-overflow-style: none !important;  /* IE and Edge */
        scrollbar-width: none !important;  /* Firefox */
      }
    </style>
  </head>
  <body
    class="bg-[var(--background)] text-[var(--foreground)] antialiased selection:bg-[#3dd0ff] selection:text-white transition-colors duration-300 relative overflow-x-hidden"
  >
    <!-- Continuous Subtle Global Glow -->
    <div class="fixed inset-0 pointer-events-none -z-50 overflow-hidden">
      <div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] rounded-full bg-blue-500/5 blur-[140px]"></div>
      <div class="absolute top-[30%] right-[-20%] w-[60%] h-[60%] rounded-full bg-blue-400/5 blur-[140px]"></div>
      <div class="absolute top-[70%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-500/5 blur-[140px]"></div>
    </div>

    <Navbar client:load />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>
